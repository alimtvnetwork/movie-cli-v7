%% 01-db-schema-diagram.mmd — Complete Database Schema (all tables + relationships)
%% Version: 2.3.0 | Updated: 2026-04-16
%% Follows: PascalCase naming, {TableName}Id PKs, Is/Has Boolean prefix
%% Single database: movie.db

erDiagram

    %% --- Lookup Tables ---

    Genre {
        INTEGER GenreId PK "AUTOINCREMENT"
        TEXT Name "NOT NULL, UNIQUE"
    }

    Cast {
        INTEGER CastId PK "AUTOINCREMENT"
        TEXT Name "NOT NULL"
        INTEGER TmdbPersonId "UNIQUE, NULLABLE"
    }

    Language {
        INTEGER LanguageId PK "AUTOINCREMENT"
        TEXT Code "NOT NULL, UNIQUE"
        TEXT Name "NOT NULL"
    }

    FileAction {
        INTEGER FileActionId PK "AUTOINCREMENT"
        TEXT Name "NOT NULL, UNIQUE"
    }

    %% --- Core Entities ---

    Collection {
        INTEGER CollectionId PK "AUTOINCREMENT"
        INTEGER TmdbCollectionId "UNIQUE, NOT NULL"
        TEXT Name "NOT NULL"
        TEXT Overview "NULLABLE"
        TEXT PosterPath "NULLABLE"
        TEXT BackdropPath "NULLABLE"
        TEXT CreatedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    Media {
        INTEGER MediaId PK "AUTOINCREMENT"
        TEXT Title "NOT NULL"
        TEXT CleanTitle "NOT NULL"
        SMALLINT Year "NULLABLE"
        TEXT Type "NOT NULL, CHECK(movie or tv)"
        INTEGER TmdbId "UNIQUE, NULLABLE"
        TEXT ImdbId "NULLABLE"
        TEXT Description "NULLABLE"
        REAL ImdbRating "NULLABLE"
        REAL TmdbRating "NULLABLE"
        REAL Popularity "NULLABLE"
        INTEGER LanguageId "FK, NULLABLE"
        INTEGER CollectionId "FK, NULLABLE"
        TEXT Director "NULLABLE"
        TEXT ThumbnailPath "NULLABLE"
        TEXT OriginalFileName "NULLABLE"
        TEXT OriginalFilePath "NULLABLE"
        TEXT CurrentFilePath "NULLABLE"
        TEXT FileExtension "NULLABLE"
        REAL FileSizeMb "NULLABLE, megabytes"
        INTEGER Runtime "DEFAULT 0, minutes"
        INTEGER Budget "DEFAULT 0"
        INTEGER Revenue "DEFAULT 0"
        TEXT TrailerUrl "NULLABLE"
        TEXT Tagline "NULLABLE"
        INTEGER ScanHistoryId "FK, NULLABLE"
        TEXT ScannedAt "DEFAULT CURRENT_TIMESTAMP"
        TEXT UpdatedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    %% --- Join Tables (Many-to-Many) ---

    MediaGenre {
        INTEGER MediaGenreId PK "AUTOINCREMENT"
        INTEGER MediaId "FK, NOT NULL"
        INTEGER GenreId "FK, NOT NULL"
    }

    MediaCast {
        INTEGER MediaCastId PK "AUTOINCREMENT"
        INTEGER MediaId "FK, NOT NULL"
        INTEGER CastId "FK, NOT NULL"
        TEXT Role "NULLABLE, character name"
        INTEGER CastOrder "NULLABLE"
    }

    %% --- Tags (Many-to-Many) ---

    Tag {
        INTEGER TagId PK "AUTOINCREMENT"
        TEXT Name "NOT NULL, UNIQUE"
        TEXT CreatedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    MediaTag {
        INTEGER MediaTagId PK "AUTOINCREMENT"
        INTEGER MediaId "FK, NOT NULL"
        INTEGER TagId "FK, NOT NULL"
        TEXT CreatedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    %% --- Scan Domain ---

    ScanFolder {
        INTEGER ScanFolderId PK "AUTOINCREMENT"
        TEXT FolderPath "NOT NULL, UNIQUE"
        BOOLEAN IsActive "NOT NULL, DEFAULT 1"
        TEXT CreatedAt "DEFAULT CURRENT_TIMESTAMP"
        TEXT UpdatedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    ScanHistory {
        INTEGER ScanHistoryId PK "AUTOINCREMENT"
        INTEGER ScanFolderId "FK, NOT NULL"
        INTEGER TotalFiles "DEFAULT 0"
        INTEGER MoviesFound "DEFAULT 0"
        INTEGER TvFound "DEFAULT 0"
        INTEGER NewFiles "DEFAULT 0"
        INTEGER RemovedFiles "DEFAULT 0"
        INTEGER UpdatedFiles "DEFAULT 0"
        INTEGER ErrorCount "DEFAULT 0"
        INTEGER DurationMs "DEFAULT 0"
        TEXT ScannedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    %% --- History and Operations ---

    MoveHistory {
        INTEGER MoveHistoryId PK "AUTOINCREMENT"
        INTEGER MediaId "FK, NOT NULL"
        INTEGER FileActionId "FK, NOT NULL"
        TEXT FromPath "NOT NULL"
        TEXT ToPath "NOT NULL"
        TEXT OriginalFileName "NULLABLE"
        TEXT NewFileName "NULLABLE"
        BOOLEAN IsReverted "NOT NULL, DEFAULT 0"
        TEXT MovedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    ActionHistory {
        INTEGER ActionHistoryId PK "AUTOINCREMENT"
        INTEGER FileActionId "FK, NOT NULL"
        INTEGER MediaId "FK, NULLABLE"
        TEXT MediaSnapshot "NULLABLE, JSON"
        TEXT Detail "NULLABLE"
        TEXT BatchId "NULLABLE, groups related actions"
        BOOLEAN IsReverted "NOT NULL, DEFAULT 0"
        TEXT CreatedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    %% --- Watchlist ---

    Watchlist {
        INTEGER WatchlistId PK "AUTOINCREMENT"
        INTEGER MediaId "FK, NULLABLE"
        INTEGER TmdbId "NOT NULL, UNIQUE"
        TEXT Title "NOT NULL"
        SMALLINT Year "NULLABLE"
        TEXT Type "CHECK(movie or tv)"
        TEXT Status "CHECK(to-watch or watched)"
        TEXT AddedAt "DEFAULT CURRENT_TIMESTAMP"
        TEXT WatchedAt "NULLABLE"
    }

    %% --- Config ---

    Config {
        TEXT ConfigKey PK "NOT NULL"
        TEXT ConfigValue "NOT NULL"
    }

    %% --- Error Log ---

    ErrorLog {
        INTEGER ErrorLogId PK "AUTOINCREMENT"
        TEXT Timestamp "NOT NULL"
        TEXT Level "NOT NULL, CHECK(ERROR or WARN or INFO)"
        TEXT Source "NOT NULL"
        TEXT Function "NULLABLE"
        TEXT Command "NULLABLE"
        TEXT WorkDir "NULLABLE"
        TEXT Message "NOT NULL"
        TEXT StackTrace "NULLABLE"
        TEXT CreatedAt "DEFAULT CURRENT_TIMESTAMP"
    }

    %% --- Relationships ---

    Language ||--o{ Media : "LanguageId"
    Collection ||--o{ Media : "CollectionId"
    ScanFolder ||--o{ ScanHistory : "has scans"
    ScanHistory ||--o{ Media : "discovered in"

    Media ||--o{ MediaGenre : "has genres"
    Genre ||--o{ MediaGenre : "used by"

    Media ||--o{ MediaCast : "has cast"
    Cast ||--o{ MediaCast : "appears in"

    Media ||--o{ MediaTag : "has tags"
    Tag ||--o{ MediaTag : "used by"

    Media ||--o{ MoveHistory : "has moves"
    FileAction ||--o{ MoveHistory : "action type"

    FileAction ||--o{ ActionHistory : "action type"
    Media ||--o{ ActionHistory : "has actions"

    Media ||--o| Watchlist : "tracked in"
