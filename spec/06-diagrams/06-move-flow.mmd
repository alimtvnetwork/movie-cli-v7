%% 06-move-flow.mmd — movie move [directory]
%% Version: 1.1.0 | Updated: 2026-04-06

flowchart TD
    A([movie move dir]) --> B{Directory arg given?}
    B -->|yes| C[Expand home path]
    B -->|no| D(Prompt source directory)

    C --> E{Validate directory}
    D --> E
    E -->|invalid| F[/Error: Directory not found/]
    E -->|valid| G[List video files]

    G --> H{Files found?}
    H -->|no| I[/No video files found/]
    H -->|yes| J[Display file list with clean names]

    J --> K(Prompt: Select file number)
    K --> L{Valid selection?}
    L -->|no| M[/Error: Invalid selection/]
    L -->|yes| N[Show selected file details]

    N --> O(Prompt destination:\nMovies / TV / Archive / Custom)
    O --> P[Build clean filename]
    P --> Q[Show move preview:\nFrom -> To]

    Q --> R(Prompt: Confirm y/N)
    R -->|no| S[/Move cancelled/]
    R -->|yes| T[Create destination directory]

    T --> U[MoveFile source -> dest]
    U --> V{Move succeeded?}
    V -->|no| W[/Error: Move failed/]
    V -->|yes| X{Media exists in DB?}

    X -->|yes| Y[Update media path]
    X -->|no| Z[Insert new media record]
    Y --> AA[Insert move history]
    Z --> AA
    AA --> AB[Save history log]
    AB --> AC[/Move successful/]

    classDef entryExit fill:#1e293b,stroke:#1e293b,color:#f1f5f9,stroke-width:2px
    classDef process fill:#f1f5f9,stroke:#cbd5e1,color:#1e293b
    classDef decision fill:#e2e8f0,stroke:#94a3b8,color:#1e293b
    classDef success fill:#22c55e,stroke:#16a34a,color:#ffffff
    classDef error fill:#ef4444,stroke:#dc2626,color:#ffffff
    classDef warning fill:#f59e0b,stroke:#d97706,color:#ffffff
    classDef info fill:#3b82f6,stroke:#2563eb,color:#ffffff
    classDef prompt fill:#8b5cf6,stroke:#7c3aed,color:#ffffff

    class A entryExit
    class C,G,J,N,P,Q,T,U,Y,Z,AA,AB process
    class B,E,H,L,V,X decision
    class AC success
    class F,I,M,W error
    class S warning
    class D,K,O,R prompt
