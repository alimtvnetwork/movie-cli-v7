%% 05-suggest-flow.mmd — movie suggest [N]
%% Version: 1.1.0 | Updated: 2026-04-06

flowchart TD
    A([movie suggest N]) --> B{Parse count arg}
    B -->|provided| C[Set count = N]
    B -->|missing| D[Default count = 10]
    C --> E[Open DB]
    D --> E

    E --> F{Get TMDb API key}
    F -->|not found| G[/Error: API key required/]
    F -->|found| H(Prompt category:\nMovie / TV / Random)

    H -->|Movie| I[suggestByType movie]
    H -->|TV| J[suggestByType tv]
    H -->|Random| K[suggestRandom]
    H -->|invalid| L[/Error: Invalid choice/]

    I --> M{Get top genres from DB}
    J --> M
    M -->|empty| N[Fallback: show trending]
    M -->|found| O[Display top 3 genres]

    O --> P[Load existing media IDs]
    P --> Q[Pick random library items]
    Q --> R[Fetch TMDb recommendations]
    R --> S{Enough suggestions?}
    S -->|no| T[Fill with trending]
    S -->|yes| U[/Print suggestions/]
    T --> U

    N --> V[Fetch trending from TMDb]
    V --> U

    K --> W[Fetch movie + TV trending]
    W --> X[Shuffle and deduplicate]
    X --> Y[Trim to count]
    Y --> U

    U --> Z([Done])

    classDef entryExit fill:#1e293b,stroke:#1e293b,color:#f1f5f9,stroke-width:2px
    classDef process fill:#f1f5f9,stroke:#cbd5e1,color:#1e293b
    classDef decision fill:#e2e8f0,stroke:#94a3b8,color:#1e293b
    classDef success fill:#22c55e,stroke:#16a34a,color:#ffffff
    classDef error fill:#ef4444,stroke:#dc2626,color:#ffffff
    classDef warning fill:#f59e0b,stroke:#d97706,color:#ffffff
    classDef info fill:#3b82f6,stroke:#2563eb,color:#ffffff
    classDef prompt fill:#8b5cf6,stroke:#7c3aed,color:#ffffff

    class A,Z entryExit
    class C,D,E,I,J,K,O,P,Q,X,Y,N process
    class B,F,M,S decision
    class U success
    class G,L error
    class R,V,W info
    class H prompt
    class T process
