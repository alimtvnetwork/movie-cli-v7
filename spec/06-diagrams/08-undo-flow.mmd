%% 08-undo-flow.mmd — movie undo
%% Version: 1.1.0 | Updated: 2026-04-06

flowchart TD
    A([movie undo]) --> B[Open DB]
    B --> C[GetLastMove from history]
    C --> D{Move found?}
    D -->|no| E[/No move operations to undo/]
    D -->|yes| F[Display last move:\nTo -> From]

    F --> G(Prompt: Undo this? y/N)
    G -->|no| H[/Undo cancelled/]
    G -->|yes| I{File exists at ToPath?}

    I -->|no| J[/Error: File not found at source/]
    I -->|yes| K[MoveFile ToPath -> FromPath]

    K --> L{Move succeeded?}
    L -->|no| M[/Error: Undo failed/]
    L -->|yes| N[Mark move as undone in DB]
    N --> O[Update media path to FromPath]
    O --> P[/Undo successful/]

    classDef entryExit fill:#1e293b,stroke:#1e293b,color:#f1f5f9,stroke-width:2px
    classDef process fill:#f1f5f9,stroke:#cbd5e1,color:#1e293b
    classDef decision fill:#e2e8f0,stroke:#94a3b8,color:#1e293b
    classDef success fill:#22c55e,stroke:#16a34a,color:#ffffff
    classDef error fill:#ef4444,stroke:#dc2626,color:#ffffff
    classDef warning fill:#f59e0b,stroke:#d97706,color:#ffffff
    classDef info fill:#3b82f6,stroke:#2563eb,color:#ffffff
    classDef prompt fill:#8b5cf6,stroke:#7c3aed,color:#ffffff

    class A entryExit
    class B,C,F,K,N,O process
    class D,I,L decision
    class P success
    class E,J,M error
    class H warning
    class G prompt
